# Frontend (Vite) environment variables - client-side. Safe to commit if non-sensitive.
# Copy to frontend/.env for local development.

# Base API URL (proxy to Netlify Dev or production API)
VITE_API_URL=/api

# Public Pusher keys (non-sensitive)
VITE_PUSHER_KEY=your_app_key
VITE_PUSHER_CLUSTER=us2
