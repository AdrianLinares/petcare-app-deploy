# Environment variables for Netlify Functions (server-side)
# Copy to netlify/functions/.env for local development and DO NOT commit

# Database (use Neon, Supabase, or other Postgres-compatible provider)
DATABASE_URL=postgresql://user:password@host:port/database

# JWT
JWT_SECRET=replace_with_strong_random_secret
JWT_EXPIRES_IN=7d

# Frontend URL
FRONTEND_URL=http://localhost:8888

# Pusher (real-time notifications)
PUSHER_APP_ID=your_app_id
PUSHER_KEY=your_app_key
PUSHER_SECRET=your_app_secret
PUSHER_CLUSTER=us2

# Optional: Edge cache configuration (same meaning as root .env.example)
EDGE_CACHE_ALLOWLIST=/api/pets,/api/appointments
EDGE_CACHE_TTL_DEFAULT=30

# NOTE: Never commit this file. Keep secrets out of the repository.
