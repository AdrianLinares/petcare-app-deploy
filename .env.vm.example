# ═══════════════════════════════════════════════════════════════════════════
# PetCare App — Variables de Entorno para VM (Ubuntu + Apache)
# ═══════════════════════════════════════════════════════════════════════════
# Copiar a .env y ajustar valores
# cp .env.vm.example .env
# ═══════════════════════════════════════════════════════════════════════════

# ── Entorno ────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
HOST=127.0.0.1

# ── Base de Datos ──────────────────────────────────────────────────────────
# PostgreSQL local (instalado por setup-vm.sh o manualmente)
DATABASE_URL=postgresql://petcare:changeme_in_prod@localhost:5432/petcare_db

# ── JWT ────────────────────────────────────────────────────────────────────
# Generar con: openssl rand -hex 32
JWT_SECRET=replace_with_strong_random_secret
JWT_EXPIRES_IN=7d

# ── Frontend ───────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost

# ── CORS ───────────────────────────────────────────────────────────────────
CORS_ORIGIN=*

# ── Pusher (opcional — notificaciones en tiempo real) ──────────────────────
# PUSHER_APP_ID=your_app_id
# PUSHER_KEY=your_app_key
# PUSHER_SECRET=your_app_secret
# PUSHER_CLUSTER=us2
