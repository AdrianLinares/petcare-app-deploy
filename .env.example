# ⚠️ WARNING: Never commit .env files to version control!
# These files contain sensitive secrets that should not be shared.
# Always keep .env files local and add them to .gitignore.

# 📋 Required Environment Variables for PetCare Application
# - DATABASE_URL: PostgreSQL connection string (use Neon, Supabase, or Railway)
# - JWT_SECRET: Strong random secret for JWT token signing (generate 32+ characters)
# - JWT_EXPIRES_IN: Token expiration time (default: 7d)
# - FRONTEND_URL: Base URL for the frontend application
# - PUSHER_APP_ID, PUSHER_KEY, PUSHER_SECRET, PUSHER_CLUSTER: For real-time notifications

# Example environment variables for local development
# Copy to .env and update values

# Database Configuration
DATABASE_URL=postgresql://user:password@host:port/database

# JWT Configuration
JWT_SECRET=replace_with_strong_random_secret
JWT_EXPIRES_IN=7d

# Frontend URL
FRONTEND_URL=http://localhost:8888

# Node Environment
NODE_ENV=development

# Pusher Configuration (Real-time notifications)
# Get credentials from https://dashboard.pusher.com
PUSHER_APP_ID=your_app_id
PUSHER_KEY=your_app_key
PUSHER_SECRET=your_app_secret
PUSHER_CLUSTER=us2

# Edge cache configuration (Netlify Edge Functions)
# Default cache TTL in seconds for GET /api/* responses
# Allowlist for cached API paths (comma-separated prefixes)
EDGE_CACHE_ALLOWLIST=/api/pets,/api/appointments,/api/medical-records,/api/vaccinations,/api/medications,/api/clinical-records,/api/notifications,/api/users
# Default cache TTL in seconds
EDGE_CACHE_TTL_DEFAULT=30
# Per-endpoint TTL overrides (prefix=seconds, comma-separated)
EDGE_CACHE_TTL_MAP=/api/appointments=15,/api/pets=60
# Roles that bypass cache (comma-separated userType values)
EDGE_CACHE_BYPASS_ROLES=administrator
